{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Multi-Tenant Contract Template Schema",
  "description": "Schema for defining dynamic multi-tenant contract templates",
  "type": "object",
  "properties": {
    "template_id": {
      "type": "string",
      "description": "Unique identifier for the template"
    },
    "base_contract": {
      "type": "object",
      "description": "Base OpenAPI contract with template variables"
    },
    "variables": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": {
          "type": "object",
          "properties": {
            "source": {
              "type": "string",
              "enum": ["discovery", "static", "runtime"]
            },
            "values": {
              "type": "array",
              "items": {"type": "string"}
            },
            "default": {"type": "string"},
            "required": {"type": "boolean"},
            "pattern": {"type": "string"}
          },
          "required": ["source"]
        }
      }
    },
    "path_template": {
      "type": "string",
      "description": "URL path template with {variable} placeholders"
    },
    "backend_template": {
      "type": "string",
      "description": "Backend URL template with {variable} placeholders"
    },
    "expansion_config": {
      "type": "object",
      "properties": {
        "max_instances": {"type": "integer", "minimum": 1},
        "variable_discovery_enabled": {"type": "boolean"},
        "cache_instances": {"type": "boolean"},
        "validate_backends": {"type": "boolean"}
      }
    },
    "discovery_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source_type": {"type": "string"},
          "connection_config": {"type": "object"},
          "variable_mapping": {"type": "object"},
          "refresh_interval": {"type": "integer"}
        },
        "required": ["source_type", "variable_mapping"]
      }
    }
  },
  "required": ["template_id", "base_contract"]
}